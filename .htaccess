RewriteEngine On
RewriteBase /tellcoexperience/

# Redirect .html URLs to clean URLs
RewriteCond %{THE_REQUEST} \s/tellcoexperience/([^\s?]+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /tellcoexperience/$1 [R=301,L]

# Internally serve matching .html files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
